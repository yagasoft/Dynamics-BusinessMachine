  "rules": [
    {
      "id": "request-basic-fields-present",
      "displayName": "Request Basic Fields Present",
      "ruleType": "validation",
      "scope": "step",
      "language": "dbm-expression-v1",
      "body": "notEmpty(request-title) and notEmpty(request-amount) and notEmpty(assigned-approver)"
    },
    {
      "id": "supporting-details-needed",
      "displayName": "Supporting Details Needed",
      "ruleType": "condition",
      "scope": "step-transition",
      "language": "dbm-expression-v1",
      "body": "request-amount >= 5000"
    },
    {
      "id": "supporting-details-complete",
      "displayName": "Supporting Details Complete",
      "ruleType": "condition",
      "scope": "step-transition",
      "language": "dbm-expression-v1",
      "body": "request-amount < 5000 or notEmpty(supporting-notes)"
    },
    {
      "id": "request-ready-for-screening",
      "displayName": "Request Ready For Screening",
      "ruleType": "condition",
      "scope": "transition",
      "language": "dbm-expression-v1",
      "body": "notEmpty(request-title) and notEmpty(request-amount) and notEmpty(assigned-approver)"
    },
    {
      "id": "screening-complete",
      "displayName": "Screening Complete",
      "ruleType": "condition",
      "scope": "step-transition",
      "language": "dbm-expression-v1",
      "body": "screening-result == 'complete'"
    },
    {
      "id": "approval-path-selected",
      "displayName": "Approval Path Selected",
      "ruleType": "condition",
      "scope": "step-transition",
      "language": "dbm-expression-v1",
      "body": "requestedOutcomeId == 'approve'"
    },
    {
      "id": "rejection-path-selected",
      "displayName": "Rejection Path Selected",
      "ruleType": "condition",
      "scope": "step-transition",
      "language": "dbm-expression-v1",
      "body": "requestedOutcomeId == 'reject'"
    },
    {
      "id": "approval-step-complete",
      "displayName": "Approval Step Complete",
      "ruleType": "validation",
      "scope": "step",
      "language": "dbm-expression-v1",
      "body": "requestedOutcomeId == 'approve'"
    },
    {
      "id": "rejection-step-complete",
      "displayName": "Rejection Step Complete",
      "ruleType": "validation",
      "scope": "step",
      "language": "dbm-expression-v1",
      "body": "requestedOutcomeId != 'reject' or notEmpty(decision-comment)"
    },
    {
      "id": "request-status-persist",
      "displayName": "Request Status Persist",
      "ruleType": "action",
      "scope": "transition",
      "language": "javascript-artifact-v1",
      "body": "artifact:request-status-update-script"
    }
  ],
