{
  "name": "dbm-portal-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "vite": "npx -p node@20.19.0 node ./node_modules/vite/bin/vite.js",
    "vitest": "npx -p node@20.19.0 node ./node_modules/vitest/vitest.mjs",
    "prepare-local-deps": "npm --prefix ../dbm-contract run build && npm --prefix ../dbm-process-experience run build",
    "build": "npm run prepare-local-deps && tsc -p tsconfig.json && npm run vite -- build",
    "test": "npm run prepare-local-deps && npm run vitest -- run",
    "start:proof": "node ./dist/src/server-entry.js"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.15",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.0",
    "jsdom": "29.0.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
