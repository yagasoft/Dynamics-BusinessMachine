{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "vitest/globals",
      "node"
    ],
    "outDir": "dist",
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "dbm-contract": [
        "../dbm-contract/dist/index.d.ts"
      ],
      "dbm-process-experience": [
        "../dbm-process-experience/dist/src/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
