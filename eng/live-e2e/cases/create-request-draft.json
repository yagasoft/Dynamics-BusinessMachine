{
  "scenarioId": "create-request-draft",
  "title": "Create request and save draft",
  "description": "Requester creates a new request in the model-driven experience and saves it as a draft.",
  "runModes": ["full"],
  "requiredRole": "requester",
  "setup": {
    "operations": []
  },
  "actions": [
    { "kind": "open-new-record-form", "entityAlias": "request", "role": "requester" },
    { "kind": "fill-field", "label": "Request Title", "value": "{{cleanupName}} Draft Request", "role": "requester" },
    { "kind": "fill-field", "label": "Request Amount", "value": "4500", "role": "requester" },
    { "kind": "click-button", "label": "Save", "role": "requester" },
    { "kind": "capture-current-record-id", "recordAlias": "requestRecord", "role": "requester" },
    { "kind": "wait-for-text", "text": "{{cleanupName}} Draft Request", "role": "requester" }
  ],
  "assertions": [
    { "kind": "record-exists", "entityAlias": "request", "recordAlias": "requestRecord" },
    { "kind": "record-field", "entityAlias": "request", "recordAlias": "requestRecord", "fieldLogicalName": "dbm_title", "equals": "{{cleanupName}} Draft Request" },
    {
      "kind": "process-state",
      "entityAlias": "request",
      "recordAlias": "requestRecord",
      "expected": {
        "stageId": "draft-request",
        "stepId": "capture-request",
        "internalStatus": "draft",
        "portalStatus": "draft"
      }
    }
  ],
  "cleanup": {
    "targets": [
      { "kind": "delete-record", "entityAlias": "request", "recordAlias": "requestRecord" }
    ]
  },
  "evidence": {
    "captureScreenshotOnSuccess": true,
    "captureTimeline": true
  }
}
