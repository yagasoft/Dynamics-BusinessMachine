{
  "scenarioId": "approval-path",
  "title": "Approval path",
  "description": "Requester submits a request and the manager approver resolves it through the approval path.",
  "runModes": ["full", "promotion"],
  "requiredRole": "requester",
  "setup": {
    "operations": []
  },
  "actions": [
    { "kind": "open-new-record-form", "entityAlias": "request", "role": "requester" },
    { "kind": "fill-field", "label": "Request Title", "value": "{{cleanupName}} Approval Path", "role": "requester" },
    { "kind": "fill-field", "label": "Request Amount", "value": "2500", "role": "requester" },
    { "kind": "set-lookup-field", "label": "Assigned Approver", "value": "{{session.userDisplayName}}", "role": "requester" },
    { "kind": "click-button", "label": "Save", "role": "requester" },
    { "kind": "capture-current-record-id", "recordAlias": "requestRecord", "role": "requester" },
    { "kind": "click-button", "label": "Submit", "role": "requester" },
    { "kind": "open-record-form", "entityAlias": "request", "recordAlias": "requestRecord", "role": "manager-approver" },
    { "kind": "wait-for-text", "text": "Under Review", "role": "manager-approver" },
    { "kind": "click-button", "label": "Approve", "role": "manager-approver" },
    { "kind": "wait-for-text", "text": "Approved", "role": "manager-approver" }
  ],
  "assertions": [
    {
      "kind": "process-state",
      "entityAlias": "request",
      "recordAlias": "requestRecord",
      "expected": {
        "stageId": "approved",
        "internalStatus": "approved",
        "portalStatus": "approved"
      }
    }
  ],
  "cleanup": {
    "targets": [
      { "kind": "delete-record", "entityAlias": "request", "recordAlias": "requestRecord" }
    ]
  },
  "evidence": {
    "captureScreenshotOnSuccess": true,
    "captureTimeline": true
  }
}
