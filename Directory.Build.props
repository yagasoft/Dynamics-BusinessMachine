<Project>
  <PropertyGroup>
    <DbmVersionPrefix Condition="'$(DbmVersionPrefix)' == ''">0.2.0</DbmVersionPrefix>
    <DbmBuildNumber Condition="'$(DbmBuildNumber)' == ''">0</DbmBuildNumber>
    <DbmVersionSuffix Condition="'$(DbmVersionSuffix)' == ''"></DbmVersionSuffix>
    <SourceRevisionId Condition="'$(SourceRevisionId)' == ''">local</SourceRevisionId>

    <DbmSemanticVersion Condition="'$(DbmSemanticVersion)' == '' and '$(DbmVersionSuffix)' != ''">$(DbmVersionPrefix)-$(DbmVersionSuffix)</DbmSemanticVersion>
    <DbmSemanticVersion Condition="'$(DbmSemanticVersion)' == '' and '$(DbmVersionSuffix)' == ''">$(DbmVersionPrefix)</DbmSemanticVersion>
    <DbmAssemblyVersion Condition="'$(DbmAssemblyVersion)' == ''">$(DbmVersionPrefix).$(DbmBuildNumber)</DbmAssemblyVersion>
    <DbmFileVersion Condition="'$(DbmFileVersion)' == ''">$(DbmVersionPrefix).$(DbmBuildNumber)</DbmFileVersion>
    <DbmInformationalVersion Condition="'$(DbmInformationalVersion)' == ''">$(DbmSemanticVersion)+$(SourceRevisionId)</DbmInformationalVersion>

    <Deterministic>true</Deterministic>
    <!-- Legacy non-SDK projects in DbmSolution do not support CI source-root mapping reliably on hosted runners. -->
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true' and '$(UsingMicrosoftNETSdk)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>
</Project>
