<section class="dbm-portal-runtime-shell" data-dbm-portal-template="request-shell">
  <div id="dbm-portal-runtime-root"></div>
  <script src="~/dbm/portal-runtime/portal-runtime.js"></script>
  <script>
    (function () {
      const root = document.getElementById('dbm-portal-runtime-root');
      const host = window.DBM && window.DBM.PortalRuntime;
      if (!root || !host || typeof host.mount !== 'function') {
        return;
      }

      host.mount(root, {
        bootstrap: window.dbmPortalRuntimeBootstrap,
        runtimeModel: window.dbmPortalRuntimeProcessModel,
        initialDraftValues: {}
      });
    })();
  </script>
</section>
